// DRAFT Firestore rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Secure Admin Bootstrap Trick
    // Admin logs in anonymously, then creates a doc with the secret password to gain admin rights.
    match /admins/{uid} {
      allow create, update: if isSignedIn() 
                    && request.auth.uid == uid 
                    && incoming().keys().hasAll(['secretPass'])
                    && incoming().size() == 1
                    && incoming().secretPass == 'Peniscola123';
      allow get: if isSignedIn() && request.auth.uid == uid;
      // No deletes to prevent tampering after creation
    }
    
    // Customers Collection
    match /customers/{customerId} {
      function isValidCustomer(data) {
        return data.size() >= 3 && data.size() <= 30
          && (data.get('name', '') is string && data.get('name', '').size() <= 200)
          && (data.get('email', '') is string && data.get('email', '').size() <= 200)
          && (data.get('orderNumber', '') is string && data.get('orderNumber', '').size() <= 128)
          && (data.get('createdAt', 0) is number || data.get('createdAt', '') is string)
          && (data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 10000000)
          && (data.get('expirationDate', '') is string && data.get('expirationDate', '').size() <= 100)
          && (data.get('hasAcceptedTerms', false) is bool)
          && (data.get('isSuspended', false) is bool)
          && (data.get('isRegular', false) is bool)
          && (data.get('type', 'annual') is string && data.get('type', 'annual') in ['annual', 'regular'])
          && (data.get('__test', false) is bool); // allow test field
      }

      // Allow get if valid ID (so users with their customer code can log in)
      allow get: if isSignedIn() && isValidId(customerId);
      // Only admin can list all customers
      allow list: if isAdmin();
      
      // Allow user to create their own profile or admin to create
      allow create: if (isSignedIn() && request.auth.uid == customerId) || isAdmin();
      
      // Allow user to update their own profile (specifically for image and terms) or admin to update
      allow update: if isSignedIn();
                    
      allow delete: if isAdmin();

      // Orders Subcollection
      match /orders/{orderId} {
        function isValidOrder(data) {
          return data.size() >= 4 && data.size() <= 20
            && (data.get('artist', '') is string && data.get('artist', '').size() <= 200)
            && (data.get('track', '') is string && data.get('track', '').size() <= 200)
            && (data.get('email', '') is string && data.get('email', '').size() <= 200)
            && (data.get('status', 'Afventer') is string && data.get('status', 'Afventer') in ['Afventer', 'I gang', 'Gennemført', 'Annulleret', 'Afventer betaling'])
            && (data.get('date', '') is string && data.get('date', '').size() <= 100)
            && (data.get('createdAt', 0) is number || data.get('createdAt', '') is string)
            && (data.get('inProgressAt', 0) is number)
            && (data.get('customerType', 'annual') is string && data.get('customerType', 'annual') in ['annual', 'regular'])
            && (data.get('priceAccepted', false) is bool)
            && (data.get('ideas', '') is string && data.get('ideas', '').size() <= 3000)
            && (data.get('link', '') is string && data.get('link', '').size() <= 1000)
            && (data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 1500)
            && (data.get('downloadUrl', '') is string && data.get('downloadUrl', '').size() <= 1500)
            && (data.get('__test', false) is bool);
        }

        // Parent document customerId must match the user's logged in code, OR user is admin
        allow read: if isAdmin() || (isSignedIn() && isValidId(customerId));
        
        allow create: if (isAdmin() || (isSignedIn() && isValidId(customerId)))
                      && isValidOrder(incoming());
                      
        allow update: if (isAdmin() || (isSignedIn() && isValidId(customerId)))
                      && isValidOrder(incoming());
        allow delete: if isAdmin();
      }

      // Customer Private Chat Subcollection
      match /messages/{messageId} {
        function isValidCustomerMessage(data) {
          return data.size() >= 5 && data.size() <= 8
            && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
            && data.senderId is string && data.senderId.size() > 0 && data.senderId.size() <= 128
            && data.senderName is string && data.senderName.size() > 0 && data.senderName.size() <= 150
            && data.isAdmin is bool
            && data.createdAt is number
            && (data.get('__test', false) is bool);
        }

        // Parent document customerId must match the user's logged in code, OR user is admin
        allow read: if isAdmin() || (isSignedIn() && isValidId(customerId));
        
        allow create: if (isAdmin() || (isSignedIn() && isValidId(customerId)))
                      && isValidCustomerMessage(incoming())
                      && incoming().keys().hasAll(['text', 'senderId', 'senderName', 'isAdmin', 'createdAt']);
                      // && (incoming().isAdmin == isAdmin()); // Ensure normal users can't spoof isAdmin=true
                      
        allow update: if isAdmin() && isValidCustomerMessage(incoming());
        allow delete: if isAdmin() || (isSignedIn() && isValidId(customerId) && existing().senderId == customerId);
      }
    }

    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    match /online_users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() 
                    && incoming().name is string && incoming().name.size() <= 150
                    && incoming().isAdmin is bool
                    && incoming().lastActive is number;
      allow delete: if isSignedIn();
    }
  }
}
